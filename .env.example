UPSTREAM_BASE_URL=https://openrouter.ai/api
UPSTREAM_API_KEY=sk-or-...
PORT=18080
DEBUG=false
VERBOSE=false

# Optional: override some or all built-in defaults.
# ALERT: Value must be valid JSON. Wrap with single quotes to avoid shell escaping issues:
#   MODEL_MAP='{"claude-sonnet-4-6":"my-model"}'
# If omitted, the proxy uses:
# {
#   "claude-haiku-4-5": "gpt-5-mini",
#   "claude-sonnet-4-6": "gpt-5.4",
#   "claude-opus-4-6": "gpt-5.4-pro"
# }
MODEL_MAP='{"claude-haiku-4-5":"gpt-5-mini","claude-sonnet-4-6":"gpt-5.4","claude-opus-4-6":"gpt-5.4-pro"}'

# --- Azure OpenAI (optional, replaces UPSTREAM_BASE_URL) ---
# AZURE_OPENAI_ENDPOINT=https://myresource.openai.azure.com
# AZURE_USE_CLI_CREDENTIAL=true
#
# When AZURE_OPENAI_ENDPOINT is set, the proxy uses the Azure OpenAI v1 API:
#   POST {endpoint}/openai/v1/responses
#
# Authentication options:
#   1. az login credential: set AZURE_USE_CLI_CREDENTIAL=true (requires Azure CLI + az login)
#   2. API key: set UPSTREAM_API_KEY to your Azure OpenAI key (sent via api-key header)
#
# MODEL_MAP values should be your Azure deployment names, e.g.:
# MODEL_MAP='{"claude-sonnet-4-6":"my-gpt5-deployment"}'